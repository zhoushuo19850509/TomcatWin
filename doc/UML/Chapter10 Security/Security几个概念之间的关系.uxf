    <coordinates>
      <x>517</x>
      <y>308</y>
      <w>209</w>
      <h>110</h>
    </coordinates>
    <panel_attributes>LoginConfig
--
// reaml具体实现类的名称
realmName
// Authenticator具体实现类的名称
// 比如BASIC, DIGEST, FORM, or CLIENT-CERT
authMethod
--
+getRealmName()
+getAuthMethod()



</panel_attributes>
